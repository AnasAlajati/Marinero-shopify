{% comment %}
  MARINERO Editorial Split Section
  Left: full-bleed image (55%). Right: vertically centred text + CTA (45%).
  Reverses on mobile. Image side and text side swap via `image_position` setting.
{% endcomment %}

<div class="marinero-editorial color-{{ section.settings.color_scheme }}{% if section.settings.image_position == 'right' %} marinero-editorial--reversed{% endif %} m-reveal">

  <div class="marinero-editorial__image">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1800
        | image_tag:
          widths: '600, 900, 1200, 1600, 1800',
          sizes: '(min-width: 750px) 55vw, 100vw',
          alt: section.settings.image.alt,
          class: 'marinero-editorial__img',
          loading: 'lazy'
      }}
    {%- else -%}
      <div class="marinero-editorial__placeholder">
        <svg viewBox="0 0 600 700" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;opacity:.15;">
          <rect width="600" height="700" fill="#0B1F3A"/>
          <circle cx="300" cy="280" r="80" stroke="#F5F0E8" stroke-width="4" fill="none"/>
          <path d="M180 440 Q180 560 300 580 Q420 560 420 440" stroke="#F5F0E8" stroke-width="4" fill="none"/>
          <line x1="220" y1="440" x2="380" y2="440" stroke="#F5F0E8" stroke-width="4"/>
          <line x1="300" y1="360" x2="300" y2="440" stroke="#F5F0E8" stroke-width="4"/>
          <circle cx="300" cy="280" r="20" fill="#F5F0E8"/>
        </svg>
      </div>
    {%- endif -%}
  </div>

  <div class="marinero-editorial__content">
    {%- if section.settings.label != blank -%}
      <span class="marinero-label">{{ section.settings.label }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="marinero-editorial__heading m-reveal m-reveal--delay-1">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="marinero-editorial__text m-reveal m-reveal--delay-2">
        {{ section.settings.text }}
      </p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '#' }}"
        class="button button--primary marinero-editorial__cta m-reveal m-reveal--delay-3"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>

</div>

{% stylesheet %}
  .marinero-editorial {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 60vh;
  }

  @media screen and (min-width: 750px) {
    .marinero-editorial {
      grid-template-columns: 55fr 45fr;
      min-height: 70vh;
    }

    .marinero-editorial--reversed {
      grid-template-columns: 45fr 55fr;
    }

    .marinero-editorial--reversed .marinero-editorial__image {
      order: 2;
    }

    .marinero-editorial--reversed .marinero-editorial__content {
      order: 1;
    }
  }

  .marinero-editorial__image {
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  .marinero-editorial__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .marinero-editorial:hover .marinero-editorial__img {
    transform: scale(1.03);
  }

  .marinero-editorial__placeholder {
    position: absolute;
    inset: 0;
    background: #0B1F3A;
  }

  .marinero-editorial__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3rem;
    background-color: var(--color-background, #F5F0E8);
  }

  @media screen and (min-width: 990px) {
    .marinero-editorial__content {
      padding: 5rem 5rem 5rem 4rem;
    }
  }

  .marinero-editorial__heading {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-foreground-heading, #0B1F3A);
    margin-block: 0.75rem 1.25rem;
    max-width: 16ch;
  }

  .marinero-editorial__text {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-foreground, #2C2C2A);
    max-width: 44ch;
    margin-bottom: 2rem;
  }

  .marinero-editorial__cta {
    align-self: flex-start;
    padding: 0.85rem 2rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial Split",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image side",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "placeholder": "NEW IN · SS25"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Dressed for every moment.</p>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "Quality fashion for the whole family. Well-made clothes at honest prices — from the youngest to the oldest."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Editorial Split",
      "settings": {
        "label": "NEW IN",
        "image_position": "left"
      }
    }
  ]
}
{% endschema %}
