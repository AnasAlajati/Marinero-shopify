{% comment %} MARINERO Category Blocks — Boys / Girls / Newborn grid {% endcomment %}

<div class="marinero-cats color-{{ section.settings.color_scheme }}">
  {%- if section.settings.heading != blank -%}
    <div class="marinero-cats__header">
      {%- if section.settings.label != blank -%}
        <span class="marinero-label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="marinero-cats__heading">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="marinero-cats__grid" style="--cat-count: {{ section.blocks.size }};">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="marinero-cat-card m-reveal m-reveal--delay-{{ forloop.index }}"
        {{ block.shopify_attributes }}
      >
        <div class="marinero-cat-card__media">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                widths: '400, 600, 800',
                sizes: '(min-width: 750px) 33vw, 50vw',
                alt: block.settings.label,
                class: 'marinero-cat-card__img',
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="marinero-cat-card__placeholder">
              <span class="marinero-cat-card__placeholder-icon">{{ block.settings.placeholder_icon | default: '👕' }}</span>
            </div>
          {%- endif -%}
          <div class="marinero-cat-card__overlay"></div>
        </div>
        <div class="marinero-cat-card__label">
          <span class="marinero-cat-card__name">{{ block.settings.label }}</span>
          <span class="marinero-cat-card__cta">{{ block.settings.cta | default: 'تسوق الآن' }} →</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .marinero-cats {
    padding: var(--section-padding-block, 5rem) var(--section-padding-inline, 2rem);
    background-color: var(--color-background);
  }

  .marinero-cats__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .marinero-cats__heading {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    color: var(--color-foreground-heading);
    margin-top: 0.5rem;
  }

  .marinero-cats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .marinero-cats__grid {
      grid-template-columns: repeat(var(--cat-count, 3), 1fr);
      gap: 1.25rem;
    }
  }

  .marinero-cat-card {
    position: relative;
    display: block;
    text-decoration: none;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--marinero-navy, #0B1F3A);
  }

  .marinero-cat-card__media {
    position: absolute;
    inset: 0;
  }

  .marinero-cat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .marinero-cat-card:hover .marinero-cat-card__img {
    transform: scale(1.06);
  }

  .marinero-cat-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #0B1F3A 0%, #1B3A5C 100%);
  }

  .marinero-cat-card__placeholder-icon {
    font-size: 4rem;
    opacity: 0.4;
  }

  .marinero-cat-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(11,31,58,0.75) 0%, rgba(11,31,58,0.1) 50%, transparent 100%);
    transition: opacity 0.4s ease;
  }

  .marinero-cat-card:hover .marinero-cat-card__overlay {
    opacity: 0.85;
  }

  .marinero-cat-card__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .marinero-cat-card__name {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    font-weight: 700;
    color: #F5F0E8;
    line-height: 1;
  }

  .marinero-cat-card__cta {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #D3CEBE;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .marinero-cat-card:hover .marinero-cat-card__cta {
    opacity: 1;
    transform: translateY(0);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Blocks",
  "tag": "section",
  "class": "section-wrapper",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "placeholder_icon",
          "label": "Placeholder icon (if no image)",
          "default": "👕"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category name",
          "default": "Girls"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "CTA text",
          "default": "تسوق الآن"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "تسوق حسب الفئة"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "ملابس لكل طفل"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Category Blocks",
      "blocks": {
        "boys": {
          "type": "category",
          "settings": { "placeholder_icon": "👦", "label": "أولاد", "cta": "تسوق الآن" }
        },
        "girls": {
          "type": "category",
          "settings": { "placeholder_icon": "👧", "label": "بنات", "cta": "تسوق الآن" }
        },
        "newborn": {
          "type": "category",
          "settings": { "placeholder_icon": "👶", "label": "مواليد", "cta": "تسوق الآن" }
        }
      },
      "block_order": ["boys", "girls", "newborn"]
    }
  ]
}
{% endschema %}
