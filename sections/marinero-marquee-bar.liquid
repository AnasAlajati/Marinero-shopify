{% comment %}
  MARINERO Marquee Bar — continuously scrolling announcement strip.
  Pure CSS, no JS. Add to the top of the homepage via the theme editor.
{% endcomment %}

<div class="marinero-marquee-bar color-{{ section.settings.color_scheme }}" aria-hidden="true">
  <div class="marinero-marquee-track">
    <span class="marinero-marquee-content">
      {%- assign msg = section.settings.message | default: 'FREE SHIPPING ON ORDERS OVER 500 TL · NEW ARRIVALS EVERY WEEK · STYLE FOR THE WHOLE FAMILY · QUALITY AT HONEST PRICES · ' -%}
      {{ msg }} {{ msg }}
    </span>
  </div>
</div>

{% stylesheet %}
  .marinero-marquee-bar {
    overflow: hidden;
    white-space: nowrap;
    background-color: var(--color-background, #0B1F3A);
    padding-block: 0.55rem;
    border-bottom: 1px solid rgba(245, 240, 232, 0.12);
  }

  .marinero-marquee-track {
    display: inline-block;
    animation: marinero-marquee 28s linear infinite;
  }

  @keyframes marinero-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marinero-marquee-content {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-foreground, #D3CEBE);
  }

  @media (prefers-reduced-motion: reduce) {
    .marinero-marquee-track { animation: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Marquee Bar",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Marquee message",
      "default": "FREE SHIPPING ON ORDERS OVER 500 TL · NEW ARRIVALS EVERY WEEK · STYLE FOR THE WHOLE FAMILY · QUALITY AT HONEST PRICES · "
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    }
  ],
  "presets": [
    {
      "name": "Marquee Bar",
      "settings": {
        "color_scheme": "scheme-3"
      }
    }
  ]
}
{% endschema %}
